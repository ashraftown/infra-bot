[Unit]
Description=Infra Bot weekly package update runner
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/opt/infra-bot/.venv/bin/infra-bot --config /etc/infra-bot/config.yaml run-update
User=root
Group=root
WorkingDirectory=/opt/infra-bot/src
Environment=PYTHONUNBUFFERED=1
