[Unit]
Description=Infra Bot Telegram polling service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/infra-bot --config /etc/infra-bot/config.yaml run-bot
Restart=always
RestartSec=5
User=infra-bot
Group=infra-bot

[Install]
WantedBy=multi-user.target

